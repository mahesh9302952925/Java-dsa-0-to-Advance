class Solution {
    public double findMaxAverage(int[] nums, int k) {
        double c = 0;
        for(int i = 0; i< k; i++){
            c = (c+nums[i]);
        }
        double max = c;
        for(int i =1; i<=nums.length-k; i++ ){
            c = (c-nums[i-1]+nums[i+k-1]);
            if(c>max){
                max = c;
            }
        }
        return max/k;
    }
}
